# App Settings
PROJECT_NAME="Secure Core Platform"
VERSION="0.1.0"
API_V1_STR="/api/v1"

# Security (Internal App Tokens - Not for Supabase)
SECRET_KEY="generate-a-secure-random-string-here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# AES Payload Encryption (for Desktop App)
AES_SECRET_KEY="32-char-long-secret-key-for-aes"

# Database (Supabase / PostgreSQL)
# For Pooler (IPv4): postgres.[project_ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL="postgresql://user:pass@host:5432/postgres"

# Supabase Settings
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_JWT_SECRET="your-jwt-secret"

# Polar.sh Settings
POLAR_API_KEY="your-polar-api-key"
POLAR_WEBHOOK_SECRET="your-polar-webhook-secret"
POLAR_ORGANIZATION_ID="your-polar-org-id"

# Redis Settings
REDIS_URL="redis://localhost:6379/0"
